# Optional AI integrations
ANTHROPIC_API_KEY=
STEAM_API_KEY=

# CS2 runtime
CS2_EXE=
CS2_STEAM_PATH=
CS2_CONTROL_BACKEND=plain
CS2_SKIP_LAUNCH=false
CS2_NETCON_PORT=2121
CS2_DEMO_READY_SETTLE_S=8
CS2_POST_SEEK_SETTLE_S=4
CS2_USE_COARSE_ROUND_SEEK=false
CS2_LAUNCH_OPTIONS=
CS2_FULLSCREEN=false
CS2_WIDTH=1920
CS2_HEIGHT=1080

# Optional HLAE backend
CS2_HLAE_EXE=
CS2_HLAE_LAUNCH_TEMPLATE=
CS2_HLAE_ARGS=
CS2_HLAE_CONFIG_DIR=
CS2_HLAE_HOOK_DLL=

# OBS
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=
OBS_OUTPUT_DIR=

# Render worker / queue
RENDER_JOB_MAX_RETRIES=1
RENDER_JOB_LEASE_TIMEOUT_S=120
RENDER_WORKER_ID=

# FFmpeg post-process
FFMPEG_EXE=ffmpeg
FFPROBE_EXE=ffprobe
POSTPROCESS_PRESET=veryfast
POSTPROCESS_CRF=20
POSTPROCESS_AUDIO_BITRATE=128k
POSTPROCESS_THUMBNAIL_OFFSET_S=1.0
POSTPROCESS_THUMBNAIL_WIDTH=1280
POSTPROCESS_TRANSCODE_TIMEOUT_S=240
POSTPROCESS_THUMBNAIL_TIMEOUT_S=45
POSTPROCESS_PROBE_TIMEOUT_S=30
POSTPROCESS_MINIMUM_OUTPUT_BYTES=10240
POSTPROCESS_REQUIRE_FFPROBE=false

# Legacy tactical renderer is removed from the active path.
ENABLE_LEGACY_TACTICAL_RENDERER=0
